# Invalid: Poor error handling
@router.get("/users/{user_id}")
async def get_user(user_id: int):
    try:
        user = db.get_user(user_id)
        return user
    except:  # Wrong: Bare except clause
        return {"error": "Something went wrong"}  # Wrong: Non-standard format
        
# Invalid: Exposing internal details
except Exception as e:
    return {
        "error": str(e),  # Wrong: Exposing internal error details
        "traceback": traceback.format_exc()  # Wrong: Never expose stack traces
    }
